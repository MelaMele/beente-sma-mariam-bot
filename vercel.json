{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "mary.jpg",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/daily-blessing",
      "destination": "api/index.py"
    },
    {
      "source": "/api",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
