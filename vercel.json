{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "mary.jpg", "use": "@vercel/static" },
    { "src": "mary.mp3", "use": "@vercel/static" },
    { "src": "calendar_data.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/daily-blessing", "dest": "api/index.py" },
    { "src": "/api/cron-reminder", "dest": "api/index.py" },
    { "src": "/api", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron-reminder",
      "schedule": "0 4,6,9,12,14,16 * * *"
    }
  ]
}
